   },
   {
    "page": 6,
    "pstyle": "TimesNewRomanPSMT@11/center",
    "text": "Common Ground Between Islam and Buddhism"
   },
   {
    "page": 7,
    "pstyle": "TimesNewRomanPSMT@11/center",
    "text": "Contents, continued"
   },
   {
    "page": 8,
    "pstyle": "TimesNewRomanPSMT@18/center",
